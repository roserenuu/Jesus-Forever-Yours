<!-- HERO -->
<section class="hero">
  {%- assign hero_bg = 'hero-bg.jpg' | asset_url -%}
  <div class="hero-bg" style="position:absolute;inset:0;background-image:url({{ hero_bg }});background-size:cover;background-position:center;z-index:0;"></div>
  <div class="hero-content">
    <!-- Logo as main hero element -->
    <img src="{{ 'logo-white.png' | asset_url }}" alt="Forever Yours" class="hero-logo"/>
    <!-- Divider line -->
    <div class="hero-divider"></div>
    <!-- Tagline -->
    <p class="hero-sub">24 intimate love letters from God's heart to yours</p>
    <!-- Buttons -->
    <div class="hero-btns">
      <a href="#book" class="btn-white">Start Your 24 Days</a>
      <a href="#love-letters" class="btn-ghost-w">Read a Love Letter</a>
    </div>
  </div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <div class="marquee-item">Forever Yours</div><div class="marquee-item">24 Days With Jesus</div>
    <div class="marquee-item">Love Letters from God</div><div class="marquee-item">Rose Renuu</div>
    <div class="marquee-item">Renew Your Mind</div><div class="marquee-item">Draw Closer to Jesus</div>
    <div class="marquee-item">Forever Yours</div><div class="marquee-item">24 Days With Jesus</div>
    <div class="marquee-item">Love Letters from God</div><div class="marquee-item">Rose Renuu</div>
    <div class="marquee-item">Renew Your Mind</div><div class="marquee-item">Draw Closer to Jesus</div>
  </div>
</div>


<!-- BOOK SOLO -->
<section style="background:#000;line-height:0;overflow:hidden;">
  <img src="{{ 'book-cover.jpg' | asset_url }}" alt="Forever Yours" style="width:100%;height:auto;display:block;max-width:100%;" class="reveal"/>
</section>

<!-- SCRIPTURE -->
<section class="scripture">
  <div style="position:relative;z-index:1;max-width:760px;margin:0 auto" class="reveal">
    <q>"I have loved you with <span>an everlasting love</span>; I have drawn you with unfailing kindness."</q>
    <p class="scripture-ref">Jeremiah 31:3</p>
  </div>
</section>

<!-- BOOK FEATURE -->
<section class="book-feature" id="book" style="grid-template-columns:1fr;">
  
  <div class="book-info">
    <p class="eyebrow reveal">Order Today</p>
    <h2 class="reveal d1">24 days.<br/><em>One love story</em><br/>that never ends.</h2>
    <p class="reveal d2">Each of the 24 love letters is paired with Scripture and dedicated journaling space. An invitation to rest in His promises and discover the comfort of His unchanging love.</p>
    <div class="bfeats reveal d2">
      <div class="bf">24 personal love letters from God to you</div>
      <div class="bf">Scripture paired with each daily reading</div>
      <div class="bf">Journaling space for your reflections</div>
      <div class="bf">Hardcover and digital editions available</div>
    </div>
    <div class="price-row reveal d3">
      <div><div class="ptag">Digital</div><div class="pval">$10</div></div>
      <div><div class="ptag">Hardcover</div><div class="pval">$20</div></div>
    </div>
    <a href="/products/forever-yours-24-days-with-jesus" class="book-btn reveal d3">Start Your 24 Days</a>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="testimonials">
  <div class="test-head">
    <h2 class="reveal">Words from<br/><em>readers like you.</em></h2>
    <p class="test-count reveal">500+ Five-Star Reviews</p>
  </div>
  <div class="test-grid">
    <div class="test-card reveal">
      <div class="test-stars">★★★★★</div>
      <p class="test-text">"Forever Yours is the devotional I did not know I needed. The way Scripture comes alive in these pages is something special. I have already gifted it to three friends."</p>
      <p class="test-author">Michelle K.</p>
    </div>
    <div class="test-card reveal d1">
      <div class="test-stars">★★★★★</div>
      <p class="test-text">"This book brought me back to a deeper relationship with God. I had been going through the motions, but the words in these pages helped me feel His presence again."</p>
      <p class="test-author">Sarah M.</p>
    </div>
    <div class="test-card reveal d2">
      <div class="test-stars">★★★★★</div>
      <p class="test-text">"Short, powerful, and straight to the heart. Perfect for busy mornings. I am on my second time reading through and it is just as powerful every time."</p>
      <p class="test-author">Jennifer L.</p>
    </div>
  
      <div class="test-card reveal">
        <div class="test-stars">★★★★★</div>
        <p class="test-text">"Each day felt like opening a personal letter from God. I cried happy tears more than once. The Scriptures chosen for each day are so perfectly paired with the message."</p>
        <p class="test-author">Emily R.</p>
      </div>
      <div class="test-card reveal d1">
        <div class="test-stars">★★★★★</div>
        <p class="test-text">"I read a lot of Christian books and this one hits different. The love letters feel so personal, like God is speaking directly to you. Finished it in a week because I could not put it down."</p>
        <p class="test-author">Stephanie R.</p>
      </div>
      <div class="test-card reveal d2">
        <div class="test-stars">★★★★★</div>
        <p class="test-text">"My teenage daughter and I are going through this together. It has opened up conversations about faith that I have been praying for. Such a gift."</p>
        <p class="test-author">Patricia E.</p>
      </div></div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-img reveal">
    <img src="{{ 'rose-renuu.jpg' | asset_url }}" alt="Rose Renuu"/>
  </div>
  <div class="about-txt">
    <p class="eyebrow reveal">Meet Rose</p>
    <h2 class="reveal d1">Written from<br/><em>her darkest</em><br/>season.</h2>
    <p class="reveal d2">Rose Renuu is a writer and content creator whose life was transformed when she encountered the love of Jesus in her darkest season. The words God placed on her heart became the foundation of Forever Yours.</p>
    <p class="reveal d2">She shares God's love through healing words and faith-filled content, reaching hundreds of thousands of people around the world from Los Angeles.</p>
    </div>
</section>

<!-- INSTAGRAM -->
<section style="padding:90px 56px;background:var(--white);text-align:center;">
  <div class="reveal" style="max-width:900px;margin:0 auto;">
    <p style="font-family:'Jost',sans-serif;font-size:10px;font-weight:500;letter-spacing:.35em;text-transform:uppercase;color:var(--walnut);display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:16px;">
      <span style="width:24px;height:1px;background:var(--walnut);display:inline-block;"></span>
      Follow Along
    </p>
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,3.6vw,42px);font-weight:400;line-height:1.1;color:var(--black);margin-bottom:8px;">
      <em style="font-style:italic;color:var(--walnut);">@roserenuu</em>
    </h2>
    <p style="font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:var(--text-m);margin-bottom:40px;">Daily love letters, scripture and faith for your feed.</p>
    <behold-widget feed-id="TNyzem3CBhcztSGk8hm5"></behold-widget>
  </div>
</section>

<!-- FAQ -->
<section style="padding:90px 56px;background:var(--white);">
  <div style="max-width:680px;margin:0 auto;">
    <p class="eyebrow reveal" style="justify-content:center">Common Questions</p>
    <h2 class="reveal" style="font-family:'Playfair Display',serif;font-size:clamp(28px,3.6vw,44px);font-weight:400;color:var(--black);text-align:center;margin-top:12px;margin-bottom:52px;">
      Everything you need to know
    </h2>

    <div class="faq-item reveal" onclick="toggleFaq(this)">
      <div class="faq-q">Is this devotional for men too?</div>
      <div class="faq-icon">+</div>
      <div class="faq-a">Absolutely. The love letters are written from God to His child, and they speak to anyone who wants to draw closer to Jesus, regardless of gender.</div>
    </div>
    <div class="faq-item reveal" onclick="toggleFaq(this)">
      <div class="faq-q">How long does each day take?</div>
      <div class="faq-icon">+</div>
      <div class="faq-a">Each daily reading takes about 10 to 15 minutes, perfect for busy mornings. The journaling space lets you go deeper if you have more time.</div>
    </div>
    <div class="faq-item reveal" onclick="toggleFaq(this)">
      <div class="faq-q">What is the difference between hardcover and digital?</div>
      <div class="faq-icon">+</div>
      <div class="faq-a">The hardcover ($20) is a beautiful physical book you can hold, write in, and gift. The digital version ($10) is a PDF you can read on any device immediately after purchase.</div>
    </div>
    <div class="faq-item reveal" onclick="toggleFaq(this)">
      <div class="faq-q">Can I go through this with a friend or small group?</div>
      <div class="faq-icon">+</div>
      <div class="faq-a">Yes! Many readers go through Forever Yours with a friend, sister, or small group. The 24-day format makes it easy to stay on the same page and share what God is speaking.</div>
    </div>
    <div class="faq-item reveal" onclick="toggleFaq(this)">
      <div class="faq-q">When will my order arrive?</div>
      <div class="faq-icon">+</div>
      <div class="faq-a">Hardcover orders typically arrive within 4 to 6 weeks. Digital orders are available immediately after purchase.</div>
    </div>
  </div>
</section>

<!-- EMAIL -->
<section style="padding:90px 24px;background:#F1EDE6;text-align:center;border-top:1px solid #E8E0D5;">
  <div class="reveal" style="max-width:520px;margin:0 auto;">
    <p style="font-family:'Jost',sans-serif;font-size:10px;font-weight:500;letter-spacing:.35em;text-transform:uppercase;color:#7C6A54;display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:16px;">
      <span style="width:24px;height:1px;background:#7C6A54;display:inline-block;"></span>
      Free Gift
    </p>
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,5vw,42px);font-weight:400;line-height:1.1;color:#141210;margin-bottom:14px;">
      Get a free Love Letter<br/><em style="font-style:italic;color:#7C6A54;">delivered to your inbox</em>
    </h2>
    <p style="font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;font-weight:300;color:#6A6058;margin-bottom:36px;line-height:1.6;">
      Sign up and receive a personal love letter from God straight to your inbox.
    </p>
    {% form 'customer' %}
  <input type="hidden" name="contact[tags]" value="newsletter">
  <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;max-width:380px;margin:0 auto;">
    <input type="email" name="contact[email]" placeholder="Your email address" required
      style="flex:1;min-width:220px;padding:14px 20px;border:1px solid rgba(20,18,16,0.18);background:var(--white);font-family:'Jost',sans-serif;font-size:13px;color:var(--black);outline:none;">
    <button type="submit"
      style="background:var(--black);color:var(--white);font-size:10px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;padding:14px 28px;border:none;cursor:pointer;font-family:'Jost',sans-serif;transition:background .3s;white-space:nowrap;">
      Join
    </button>
  </div>
  {%- if form.posted_successfully? -%}
    <p style="margin-top:14px;font-family:'Cormorant Garamond',serif;font-size:16px;font-style:italic;color:var(--walnut);">Thank you for joining. Check your inbox.</p>
  {%- elsif form.errors -%}
    <p style="margin-top:14px;font-size:12px;color:#c0392b;">{{ form.errors | default_errors }}</p>
  {%- endif -%}
{% endform %}
    <p style="font-family:'Jost',sans-serif;font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#A09888;">No spam. Just love letters.</p>
  </div>
</section>

