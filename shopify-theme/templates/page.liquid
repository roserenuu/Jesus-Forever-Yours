<!-- Generic Page Template -->
<section style="padding:80px 56px;max-width:900px;margin:0 auto;">
  <h1 style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,52px);font-weight:400;color:#141210;margin-bottom:32px;line-height:1.1;">
    {{ page.title }}
  </h1>
  <div style="font-family:'Cormorant Garamond',serif;font-size:19px;line-height:1.8;color:#6A6058;">
    {{ page.content }}
  </div>
</section>
